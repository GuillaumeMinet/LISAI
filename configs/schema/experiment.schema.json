{
  "$defs": {
    "ArtificialMovementParams": {
      "additionalProperties": false,
      "description": "Parameters controlling synthetic motion applied to timelapse sequences.",
      "properties": {
        "movement_type": {
          "const": "translation",
          "default": "translation",
          "description": "Synthetic motion model applied to the stack. Only 'translation' is currently supported.",
          "title": "Movement Type",
          "type": "string"
        },
        "speed": {
          "description": "Base movement speed in pixels per frame.",
          "title": "Speed",
          "type": "number"
        },
        "direction": {
          "description": "Movement direction. Use 'random' to sample directions dynamically.",
          "enum": [
            "random",
            "h+",
            "h-",
            "v+",
            "v-",
            "h+v+",
            "h+v-",
            "h-v+",
            "h-v-"
          ],
          "title": "Direction",
          "type": "string"
        },
        "nFrames": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional number of frames to move. Use null to use the full input sequence length.",
          "title": "Nframes"
        },
        "dynamic_direction": {
          "default": false,
          "description": "Whether direction can change over time. Requires direction='random'.",
          "title": "Dynamic Direction",
          "type": "boolean"
        },
        "variable_speed": {
          "default": false,
          "description": "Whether movement speed can vary during the sequence.",
          "title": "Variable Speed",
          "type": "boolean"
        },
        "keep_center_fixed": {
          "default": false,
          "description": "Whether the effective crop should stay centered while movement is applied.",
          "title": "Keep Center Fixed",
          "type": "boolean"
        },
        "keep_input_size": {
          "default": false,
          "description": "Whether the transformed output should preserve the original input size.",
          "title": "Keep Input Size",
          "type": "boolean"
        }
      },
      "required": [
        "speed",
        "direction"
      ],
      "title": "ArtificialMovementParams",
      "type": "object"
    },
    "DownsamplingMultipleParams": {
      "additionalProperties": false,
      "description": "Parameters specific to the 'multiple' downsampling method.",
      "properties": {
        "fill_factor": {
          "description": "Fraction of pixels kept in each generated sparse observation, in the interval (0, 1].",
          "title": "Fill Factor",
          "type": "number"
        },
        "random": {
          "default": false,
          "description": "Whether each generated observation should use a random sparse sampling pattern.",
          "title": "Random",
          "type": "boolean"
        }
      },
      "required": [
        "fill_factor"
      ],
      "title": "DownsamplingMultipleParams",
      "type": "object"
    },
    "DownsamplingParams": {
      "additionalProperties": false,
      "description": "Parameters controlling synthetic low-resolution input generation for upsampling training.",
      "properties": {
        "supervised_training": {
          "default": true,
          "description": "Whether the downsampled input is paired with a supervised target during training.",
          "title": "Supervised Training",
          "type": "boolean"
        },
        "downsamp_factor": {
          "description": "Spatial downsampling factor applied to the input.",
          "title": "Downsamp Factor",
          "type": "integer"
        },
        "downsamp_method": {
          "description": "Downsampling strategy. Supported values are blur, multiple, random, real, and all.",
          "enum": [
            "blur",
            "multiple",
            "random",
            "real",
            "all"
          ],
          "title": "Downsamp Method",
          "type": "string"
        },
        "multiple_prm": {
          "anyOf": [
            {
              "$ref": "#/$defs/DownsamplingMultipleParams"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Extra parameters used when downsamp_method is 'multiple'."
        },
        "sampling_strategy": {
          "anyOf": [
            {
              "items": {
                "items": {
                  "type": "integer"
                },
                "type": "array"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Explicit real-sampling positions as two rows: y indices then x indices.",
          "title": "Sampling Strategy"
        }
      },
      "required": [
        "downsamp_factor",
        "downsamp_method"
      ],
      "title": "DownsamplingParams",
      "type": "object"
    },
    "ExperimentDataSection": {
      "additionalProperties": true,
      "properties": {
        "dataset_name": {
          "default": "unknown_dataset",
          "title": "Dataset Name",
          "type": "string"
        },
        "canonical_load": {
          "default": true,
          "title": "Canonical Load",
          "type": "boolean"
        },
        "prep_before": {
          "default": true,
          "title": "Prep Before",
          "type": "boolean"
        },
        "already_split": {
          "default": true,
          "title": "Already Split",
          "type": "boolean"
        },
        "paired": {
          "default": false,
          "title": "Paired",
          "type": "boolean"
        },
        "input": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Input"
        },
        "target": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Target"
        },
        "inp": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Inp"
        },
        "gt": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Gt"
        },
        "data_format": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Data Format"
        },
        "filters": {
          "items": {
            "type": "string"
          },
          "title": "Filters",
          "type": "array"
        },
        "batch_size": {
          "default": 1,
          "title": "Batch Size",
          "type": "integer"
        },
        "patch_size": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Patch Size"
        },
        "val_patch_size": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Val Patch Size"
        },
        "patch_thresh": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Patch Thresh"
        },
        "select_on_gt": {
          "default": false,
          "title": "Select On Gt",
          "type": "boolean"
        },
        "augmentation": {
          "default": false,
          "title": "Augmentation",
          "type": "boolean"
        },
        "initial_crop": {
          "anyOf": [
            {},
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Initial Crop"
        },
        "mltpl_noise": {
          "default": false,
          "title": "Mltpl Noise",
          "type": "boolean"
        },
        "inp_transform": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Inp Transform"
        },
        "gt_transform": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Gt Transform"
        },
        "timelapse_prm": {
          "anyOf": [
            {
              "$ref": "#/$defs/TimelapseParams"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Timelapse-specific loading options, used for temporal datasets."
        },
        "mltpl_snr_prm": {
          "anyOf": [
            {
              "$ref": "#/$defs/MultipleSnrParams"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Multi-SNR selection options, used when a dataset contains several noise levels per sample."
        },
        "downsampling": {
          "anyOf": [
            {
              "$ref": "#/$defs/DownsamplingParams"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Upsampling-training settings for generating downsampled model inputs."
        },
        "artificial_movement": {
          "anyOf": [
            {
              "$ref": "#/$defs/ArtificialMovementParams"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Upsampling-training settings for adding synthetic motion to temporal inputs."
        },
        "norm_prm": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Norm Prm"
        },
        "model_norm_prm": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Model Norm Prm"
        },
        "avgObs_per_noise": {
          "anyOf": [
            {
              "items": {
                "type": "number"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Avgobs Per Noise"
        },
        "stdObs_per_noise": {
          "anyOf": [
            {
              "items": {
                "type": "number"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Stdobs Per Noise"
        }
      },
      "title": "ExperimentDataSection",
      "type": "object"
    },
    "ExperimentLoadModelSection": {
      "additionalProperties": true,
      "properties": {
        "canonical_load": {
          "default": true,
          "title": "Canonical Load",
          "type": "boolean"
        },
        "dataset_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Dataset Name"
        },
        "subfolder": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Subfolder"
        },
        "exp_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Exp Name"
        },
        "name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Name"
        },
        "model_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Model Name"
        },
        "model_full_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Model Full Path"
        },
        "load_method": {
          "anyOf": [
            {
              "enum": [
                "state_dict",
                "full_model"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Load Method"
        },
        "best_or_last": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Best Or Last"
        },
        "epoch_number": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Epoch Number"
        }
      },
      "title": "ExperimentLoadModelSection",
      "type": "object"
    },
    "ExperimentSection": {
      "additionalProperties": true,
      "properties": {
        "mode": {
          "default": "train",
          "enum": [
            "train",
            "continue_training",
            "retrain"
          ],
          "title": "Mode",
          "type": "string"
        },
        "exp_name": {
          "default": "unnamed_experiment",
          "title": "Exp Name",
          "type": "string"
        },
        "overwrite": {
          "default": false,
          "title": "Overwrite",
          "type": "boolean"
        },
        "post_training_inference": {
          "default": false,
          "title": "Post Training Inference",
          "type": "boolean"
        }
      },
      "title": "ExperimentSection",
      "type": "object"
    },
    "ModelSection": {
      "additionalProperties": true,
      "properties": {
        "architecture": {
          "default": "",
          "title": "Architecture",
          "type": "string"
        },
        "parameters": {
          "additionalProperties": true,
          "title": "Parameters",
          "type": "object"
        }
      },
      "title": "ModelSection",
      "type": "object"
    },
    "MultipleSnrParams": {
      "additionalProperties": false,
      "description": "Options used when selecting a noise level from multi-SNR datasets.",
      "properties": {
        "snr_idx": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "items": {
                "type": "integer"
              },
              "type": "array"
            },
            {
              "enum": [
                "last",
                "random"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Noise level selection strategy: a single index, a list of indices, 'last', 'random', or null.",
          "title": "Snr Idx"
        }
      },
      "title": "MultipleSnrParams",
      "type": "object"
    },
    "NoiseModelSection": {
      "additionalProperties": true,
      "properties": {
        "name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Name"
        }
      },
      "title": "NoiseModelSection",
      "type": "object"
    },
    "RoutingSection": {
      "additionalProperties": true,
      "properties": {
        "data_subfolder": {
          "default": "",
          "title": "Data Subfolder",
          "type": "string"
        },
        "models_subfolder": {
          "default": "",
          "title": "Models Subfolder",
          "type": "string"
        },
        "tensorboard_subfolder": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tensorboard Subfolder"
        },
        "inference_subfolder": {
          "default": "",
          "title": "Inference Subfolder",
          "type": "string"
        }
      },
      "title": "RoutingSection",
      "type": "object"
    },
    "SavingSection": {
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "default": true,
          "title": "Enabled",
          "type": "boolean"
        },
        "canonical_save": {
          "default": true,
          "title": "Canonical Save",
          "type": "boolean"
        },
        "validation_images": {
          "default": true,
          "title": "Validation Images",
          "type": "boolean"
        },
        "validation_freq": {
          "default": 10,
          "title": "Validation Freq",
          "type": "integer"
        },
        "state_dict": {
          "default": false,
          "title": "State Dict",
          "type": "boolean"
        },
        "entire_model": {
          "default": false,
          "title": "Entire Model",
          "type": "boolean"
        },
        "overwrite_best": {
          "default": true,
          "title": "Overwrite Best",
          "type": "boolean"
        }
      },
      "title": "SavingSection",
      "type": "object"
    },
    "TensorboardSection": {
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "default": false,
          "title": "Enabled",
          "type": "boolean"
        }
      },
      "title": "TensorboardSection",
      "type": "object"
    },
    "TimelapseParams": {
      "additionalProperties": false,
      "description": "Options used when loading timelapse datasets.",
      "properties": {
        "timelapse_max_frames": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional maximum number of frames to load from each timelapse stack.",
          "title": "Timelapse Max Frames"
        },
        "context_length": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Odd temporal window size centered on the current frame. Use null to keep the full sequence.",
          "title": "Context Length"
        },
        "shuffle": {
          "default": false,
          "description": "Whether timelapse frames should be shuffled before sampling.",
          "title": "Shuffle",
          "type": "boolean"
        }
      },
      "title": "TimelapseParams",
      "type": "object"
    },
    "TrainingSection": {
      "additionalProperties": true,
      "properties": {
        "n_epochs": {
          "default": 1,
          "title": "N Epochs",
          "type": "integer"
        },
        "batch_size": {
          "default": 1,
          "title": "Batch Size",
          "type": "integer"
        },
        "learning_rate": {
          "default": 0.0001,
          "title": "Learning Rate",
          "type": "number"
        },
        "optimizer": {
          "default": "Adam",
          "title": "Optimizer",
          "type": "string"
        },
        "scheduler": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Scheduler"
        },
        "progress_bar": {
          "default": false,
          "title": "Progress Bar",
          "type": "boolean"
        },
        "early_stop": {
          "default": false,
          "title": "Early Stop",
          "type": "boolean"
        },
        "pos_encod": {
          "default": false,
          "title": "Pos Encod",
          "type": "boolean"
        }
      },
      "title": "TrainingSection",
      "type": "object"
    }
  },
  "additionalProperties": true,
  "description": "User-authored training experiment YAML schema.",
  "properties": {
    "experiment": {
      "$ref": "#/$defs/ExperimentSection"
    },
    "routing": {
      "$ref": "#/$defs/RoutingSection"
    },
    "data": {
      "$ref": "#/$defs/ExperimentDataSection"
    },
    "model": {
      "$ref": "#/$defs/ModelSection"
    },
    "training": {
      "$ref": "#/$defs/TrainingSection"
    },
    "normalization": {
      "additionalProperties": true,
      "title": "Normalization",
      "type": "object"
    },
    "model_norm_prm": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Model Norm Prm"
    },
    "loss_function": {
      "additionalProperties": true,
      "title": "Loss Function",
      "type": "object"
    },
    "noise_model": {
      "anyOf": [
        {
          "$ref": "#/$defs/NoiseModelSection"
        },
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Noise Model"
    },
    "saving": {
      "$ref": "#/$defs/SavingSection"
    },
    "tensorboard": {
      "$ref": "#/$defs/TensorboardSection"
    },
    "load_model": {
      "$ref": "#/$defs/ExperimentLoadModelSection"
    }
  },
  "title": "ExperimentConfig",
  "type": "object"
}
