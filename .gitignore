# Local machine config
configs/local_config.yml

# Ignore local training configs directly inside configs/training/
configs/training/local/*
configs/training/sweeps/*

# But keep subdirectories visible to Git rules and track templates/examples
!configs/training/local/.gitkeep
!configs/training/*/
!configs/training/templates/**
!configs/training/examples/**

# internal lisai cache
.lisai/

# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Test / lint / type-check caches
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Coverage artifacts
.coverage
.coverage.*
htmlcov/

# Build and packaging artifacts
build/
dist/
.eggs/
*.egg-info/
pip-wheel-metadata/

# Notebook caches
.ipynb_checkpoints/

# IDE/editor settings
.vscode/
.idea/

# codex guidance
AGENTS.md

# Local Codex metadata
.codex/

# Common OS artifacts
.DS_Store
Thumbs.db
